# Shortform News Aggregator - Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
# The public origin of your deployed app. Used to restrict CORS on API routes.
APP_ORIGIN=https://shortform.news

# ── Frontend (VITE_ prefix = bundled into client JS) ─────────────────────────
VITE_USE_MOCK_API=true
VITE_API_URL=http://localhost:3000/api
VITE_ENVIRONMENT=development

# Feature Flags (Optional)
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_COMMENTS=false
VITE_ENABLE_SOCIAL_SHARE=true

# Cache Configuration (Optional)
VITE_CACHE_DURATION_HOURS=24
VITE_MAX_ARTICLES_PER_REQUEST=30

# ── Distributed Cache — Upstash Redis (Optional but Recommended for Production) ─
# When set, all serverless instances share one cache instead of each having a
# separate in-memory copy. Get your credentials at https://console.upstash.com
# Leave blank to fall back to in-process caching (fine for development / low traffic).
UPSTASH_REDIS_REST_URL=https://YOUR-UPSTASH-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Analytics (Optional)
VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
VITE_PLAUSIBLE_DOMAIN=shortform.news

# Error Tracking (Optional)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Supabase — public values (safe to expose to the browser)
#   URL and anon key: Supabase → Settings → API → Project URL / anon public
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Server-side only (Vercel env vars — NEVER expose to the frontend) ─────────
# Clerk
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Supabase service role key — server-side only; grants full DB access
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# News data APIs
NEWS_API_KEY=your_newsapi_key_here
WORLD_NEWS_API_KEY=your_world_news_api_key_here
NEWS_DATA_API_KEY=your_news_data_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here
GUARDIAN_API_KEY=your_guardian_api_key_here

# Additional news APIs (optional fallbacks)
# Currents API — 600 req/day free tier. Positioned before Guardian as a general fallback.
# Get key at: https://currentsapi.services/en/register
CURRENTS_API_KEY=your_currents_api_key_here
# MediaStack — ~500 req/month free tier (~16/day). Non-English specialist; only called
# when showNonEnglish=true and country is not English-primary. Paid plans at mediastack.com.
# Get key at: https://mediastack.com/signup
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# Optional: override daily limits to match your subscription tier
# NEWS_API_DAILY_LIMIT=100
# WORLDNEWS_DAILY_LIMIT=500
# NEWSDATA_DAILY_LIMIT=200
# GUARDIAN_DAILY_LIMIT=5000
# GNEWS_DAILY_LIMIT=100
# CURRENTS_DAILY_LIMIT=600
# MEDIASTACK_DAILY_LIMIT=16

# ── AI Summarisation — multi-provider fallback chain ──────────────────────────
# Server-side only. The server tries providers in order (Gemini → Groq → OpenAI → Cohere)
# and automatically falls back to the next when a provider's free quota is exhausted.

# 1. Google Gemini (free tier: gemini-2.0-flash-lite)
#    https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Groq (free tier: llama-3.1-8b-instant, ~14 400 req/day)
#    https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# 3. OpenAI (gpt-4o-mini, pay-per-use but very cheap)
#    https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 4. Cohere (free trial: command-r-08-2024)
#    https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# ── RSS Feed URL overrides (optional) ─────────────────────────────────────────
# All RSS feed URLs have sensible defaults; only set these if you need to swap
# in a different endpoint (e.g. a category-specific feed or a mirrored URL).

# Non-English native-language feeds
# SPIEGEL_RSS_URL=https://www.spiegel.de/schlagzeilen/index.rss
# LEMONDE_RSS_URL=https://www.lemonde.fr/rss/une.xml
# ELPAIS_RSS_URL=https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/portada
# FOLHA_RSS_URL=https://feeds.folha.com/folha/mundo/rss091.xml
# RTP_RSS_URL=https://www.rtp.pt/noticias/?format=feed&type=rss
# BBC_ARABIC_RSS_URL=https://feeds.bbci.co.uk/arabic/rss.xml
# AJ_ARABIC_RSS_URL=https://www.aljazeera.net/xmlrssfeeds/mritems/htmlfiles/rss20.xml
# NHK_JP_RSS_URL=https://www.nhk.or.jp/rss/news/cat0.xml
# YONHAP_RSS_URL=https://www.yna.co.kr/RSS/headline.xml
# MEDUZA_RU_RSS_URL=https://meduza.io/rss/ru/all
# NOS_RSS_URL=https://feeds.nos.nl/nosnieuws
# ANSA_RSS_URL=https://www.ansa.it/sito/notizie/top/top_rss.xml
# TVN24_RSS_URL=https://tvn24.pl/najnowsze.xml
